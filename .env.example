# PostgreSQL — used by the postgres service and the backend DATABASE_URL
POSTGRES_USER=accucery
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=accucery
DATABASE_URL=postgresql://accucery:change_me_in_production@postgres:5432/accucery

# Backend — set FRONTEND_URL to your VPS domain or IP for CORS
FRONTEND_URL=http://your-vps-ip-or-domain
NODE_ENV=production

# Checkers scraper — paste the full Cookie header string from browser DevTools.
# The aws-waf-token expires periodically; refresh it by copying from DevTools
# on checkers.co.za and updating this value, then restarting the backend.
CHECKERS_COOKIES=
