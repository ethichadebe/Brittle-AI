generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model List {
  id        String     @id @default(uuid())
  storeSlug String
  name      String
  createdAt DateTime   @default(now())
  userId    String?
  items     ListItem[]

  @@map("lists")
}

model PriceCache {
  storeSlug    String
  productId    String
  productName  String
  regularPrice Decimal
  loyaltyPrice Decimal?
  scrapedAt    DateTime

  @@id([storeSlug, productId])
  @@map("price_cache")
}

model ListItem {
  id          String   @id @default(uuid())
  listId      String
  productId   String
  productName String
  imageUrl    String
  regularPrice Decimal
  loyaltyPrice Decimal?
  quantity    Int      @default(1)
  isChecked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@map("list_items")
}
